# SmartOps Foundry — Automation Pilot environment template
# Copy to .env and fill in. NEVER commit .env. NEVER hardcode these in code.

# -- AI (OpenRouter) --
OPENROUTER_API_KEY=PUT_YOUR_OPENROUTER_KEY_HERE
# -- Models --
LIFE...

# -- Twilio (SMS + Voice) --
TWILIO_ACCOUNT_SID=AC_YOUR_TWILIO_SID_HERE
TWILIO_AUTH_TOKEN=PUT_YOUR_TWILIO_TOKEN_HERE
TWILIO_PHONE_NUMBER=PUT_YOUR_TWILIO_NUMBER_HERE

# -- Resend (Email) --
RESEND_API_KEY=PUT_YOUR_RESEND_KEY_HERE
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_WEBHOOK_SECRET=PUT_YOUR_RESEND_WEBHOOK_SECRET_HERE

# -- Safety allowlists (TEST_MODE only) --
# Comma-separated. In test mode, outbound SMS/email only goes to these.
TEST_PHONE_ALLOWLIST=+15000000006
TEST_FORWARD_PHONE=+15000000006
TEST_EMAIL_ALLOWLIST=you@example.com

# -- Public base URL (for webhook callback URLs) --
# Use your Cloudflare Tunnel URL when receiving real webhooks.
PUBLIC_BASE_URL=http://localhost:8787

# -- Scheduler tunables --
DEFAULT_TIMEZONE=UTC
AUTOMATION_POLL_SECONDS=5
TEST_FOLLOWUP_MINUTES=2

# -- Storage --
# Where agency + pilot data lives. Defaults to ./agency-data (project root).
AGENCY_DATA_DIR=./agency-data

# -- Hermes binary (optional, used by 'site' mode in server.mjs) --
# Leave as 'hermes' if on PATH, or set absolute path.
HERMES_BIN=hermes
